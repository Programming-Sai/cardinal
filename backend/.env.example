# Server
PORT=5000
NODE_ENV=development

# Database
# Neon connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/cardinal_immersions?sslmode=require
# If you use a custom Postgres provider that still needs SSL, set this to true
DATABASE_SSL=true

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@cardinalimmersions.com

# Frontend / CORS
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# First admin bootstrap
FIRST_ADMIN_EMAIL=admin@cardinalimmersions.com
FIRST_ADMIN_PASSWORD=change-me-now
FIRST_ADMIN_FULL_NAME=System Administrator

# Optional seed behavior
SEED_DEMO_PROGRAMS=true
